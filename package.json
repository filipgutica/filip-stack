{
  "name": "filip-stack",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "repository": "https://github.com/filipgutica/filip-stack.git",
  "engines": {
    "node": ">=20.16.0"
  },
  "scripts": {
    "build:ts": "tsc -p tsconfig.build.json",
    "build:plugins": "node scripts/build-plugins.mjs",
    "build": "pnpm build:ts && pnpm build:plugins",
    "stamp-version": "node scripts/stamp-version.mjs",
    "validate-claude-plugin": "node scripts/validate-claude-plugin.mjs",
    "generate:codex-app-server-types": "node scripts/generate-codex-app-server-types.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "check": "pnpm typecheck && pnpm test && pnpm build"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "marked": "^15.0.7",
    "marked-terminal": "^7.3.0",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "@types/yargs": "^17.0.33",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
